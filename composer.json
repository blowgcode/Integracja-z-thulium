{
  "name": "vipmartour/thulium-bridge",
  "description": "Niezależny bridge synchronizujący dane MySQL do Thulium",
  "type": "project",
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "ext-pdo": "*",
    "vlucas/phpdotenv": "^5.6",
    "monolog/monolog": "^3.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "ThuliumBridge\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ThuliumBridge\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --colors=always"
  }
}
